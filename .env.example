# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-min-32-chars-change-in-production

# 管理者（Credentials）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure-password

# DB（SQLite はファイルパスのみ。本番は Postgres 可）
DATABASE_URL="file:./dev.db"

# 監視：Slack 通知
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SITE_URL=http://localhost:3000
# 確認済みリンク用の署名シークレット（32文字以上推奨）
SLACK_ACTION_TOKEN=your-slack-action-secret-min-32-chars
# 監視ジョブ実行用（POST /api/monitor/run の Bearer トークン）
MONITOR_RUN_TOKEN=your-monitor-run-token
